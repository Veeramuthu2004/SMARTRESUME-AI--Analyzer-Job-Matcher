# Server environment variables example
# Copy to server/.env and fill in values before running in development or production

# Node / server
NODE_ENV=development
PORT=5000

# MongoDB (use a persistent MongoDB for reliable testing)
# Example: mongodb://localhost:27017/sra-dev or your Atlas connection string
MONGODB_URI=mongodb://localhost:27017/sra-dev
MONGO_URI=mongodb://localhost:27017/sra-dev

# Client
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth / Social login
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Jobs provider configuration
# jobs provider: none | rapidapi | adzuna | remotive | arbeitnow
JOBS_PROVIDER=none
JOBS_RAPIDAPI_KEY=
JOBS_RAPIDAPI_HOST=jsearch.p.rapidapi.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Email / SMTP (for forgot-password, notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@smartresume.ai

# AI keys (optional)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Misc
JOBS_DEFAULT_PAGE_SIZE=20
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart_resume_ai
MONGO_DB_NAME=smart_resume_ai
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_URL=https://your-gemini-endpoint.example.com/generate
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
AI_PROVIDER=heuristic
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM=noreply@smartresume.dev
SUPPORT_EMAIL=support@smartresume.dev
# Secret used for protected admin seeding endpoint
# Set this in production (Render) before using /dev/seed-admin-protected
SEED_SECRET=replace_with_a_random_secret
